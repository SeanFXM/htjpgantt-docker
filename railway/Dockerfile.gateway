# Railway 网关：Hotone Japan 前端 + Taiga 后端代理
# 从 GHCR 拉取前端，合并 nginx 代理配置
FROM ghcr.io/seanfxm/htjpgantt-front:latest AS frontend

FROM nginx:1.23-alpine

# 彻底移除默认 entrypoint 脚本，避免干扰配置
RUN rm -rf /docker-entrypoint.d/ && mkdir -p /docker-entrypoint.d

COPY --from=frontend /usr/share/nginx/html /usr/share/nginx/html
COPY railway/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80 8080
